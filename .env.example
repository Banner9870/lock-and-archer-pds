# Required - set these before first deploy
# Generate with: openssl rand --hex 16
PDS_JWT_SECRET=
PDS_ADMIN_PASSWORD=

# Required - your PDS public URL (no trailing slash). On Railway use the generated domain, e.g. https://your-pds.up.railway.app
PDS_HOSTNAME=

# Required - PLC rotation key (hex). Generate with:
# openssl ecparam -name secp256k1 -genkey -noout -outform DER | tail -c +8 | head -c 32 | xxd -p -c 32
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=

# Optional - defaults to /pds (use Railway volume mount)
# PDS_DATA_DIRECTORY=/pds
# Disk blobstore (required if not using S3). Default in Dockerfile: /pds/blocks
# PDS_BLOBSTORE_DISK_LOCATION=/pds/blocks

# Optional - SMTP for email verification (e.g. Resend)
# PDS_EMAIL_SMTP_URL=smtps://resend:YOUR_KEY@smtp.resend.com:465/
# PDS_EMAIL_FROM_ADDRESS=noreply@yourdomain.com
